    {
      "name": " GameText_07_EnglishPersonalityTest",
      "entries": [
        {
          "key": 62,
          "value": " You are at the beginning of an adventure, which companion would you bring with you?"
        },
        {
          "key": 66,
          "value": " A talented bluebird"
        },
        {
          "key": 67,
          "value": " A tough lizard"
        },
        {
          "key": 68,
          "value": " A wise raccoon"
        },
        {
          "key": 69,
          "value": " A resourceful lynx"
        },
        {
          "key": 63,
          "value": " During your travels, you and your companion are tired and need to rest. Where do you decide to spend the night?"
        },
        {
          "key": 70,
          "value": " A cozy cabin"
        },
        {
          "key": 71,
          "value": " An opulent palace"
        },
        {
          "key": 72,
          "value": " A secure bunker"
        },
        {
          "key": 64,
          "value": " You and your companion find a basket capable of creating any and all kinds of food out of thin air. What do you do?"
        },
        {
          "key": 73,
          "value": " Woo! Cheese party!"
        },
        {
          "key": 74,
          "value": " End world hunger"
        },
        {
          "key": 75,
          "value": " Make money."
        },
        {
          "key": 65,
          "value": " On your way home, you are ambushed. They grab the basket and your companion and run in opposite directions. \\nWhat do you do?"
        },
        {
          "key": 76,
          "value": " Chase the basket"
        },
        {
          "key": 77,
          "value": " Chase your companion"
        }
